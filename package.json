{
  "name": "audienceforge-js",
  "version": "0.2.0",
  "description": "Official JavaScript/TypeScript SDK for AudienceForge — feature flags and A/B testing.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "feature-flags",
    "ab-testing",
    "experiments",
    "audienceforge",
    "sdk"
  ],
  "author": "AudienceForge",
  "license": "MIT",
  "homepage": "https://audienceforge.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexandrehpiva/audienceforge-js.git"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^1.6.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
